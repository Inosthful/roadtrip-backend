### Variables globales
@baseUrl = http://localhost:3333
# ⚠️ Remplace cette valeur après le login !
@token = oat_NA.aFFyVGlGWEtkNHlJaW5zZUxISWN6MTEtSTZGekN5Ym5ZTm1nRzRLMjM3MTU4MDM5MQ
@tripId = 1

###############################################
# 🔐 AUTHENTIFICATION
###############################################

### 1. Créer un compte
# @name test
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "fullName": "Test User",
  "email": "test6@example.com",
  "password": "password123"
}

###
@token = {{test.response.body.data.token}}
### 2. Se connecter (COPIE LE TOKEN !)
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "test2@example.com",
  "password": "password123"
}

### 3. Voir mon profil (protégé)
GET {{baseUrl}}/auth/me
Authorization: Bearer {{token}}

### 4. Se déconnecter
POST {{baseUrl}}/auth/logout
Authorization: Bearer {{token}}

###############################################
# 🗺️ VOYAGES (TRIPS)
###############################################

### 5. Lister tous mes voyages
GET {{baseUrl}}/trips
Authorization: Bearer {{token}}

### 6. Créer un nouveau voyage
POST {{baseUrl}}/trips
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": "Voyage en Italie",
  "description": "Road trip à travers la Toscane",
  "startDate": "2025-07-01",
  "endDate": "2025-07-15",
  "budget": 2500
}

### 7. Voir un voyage spécifique (avec relations)
GET {{baseUrl}}/trips/{{tripId}}
Authorization: Bearer {{token}}

### 8. Modifier un voyage
PATCH {{baseUrl}}/trips/{{tripId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": "Voyage en Italie - MODIFIÉ",
  "status": "active",
  "budget": 3000
}

### 9. Supprimer un voyage
DELETE {{baseUrl}}/trips/{{tripId}}
Authorization: Bearer {{token}}

###############################################
# 🧪 TESTS D'ERREURS
###############################################

### 10. Tenter d'accéder sans token (401)
GET {{baseUrl}}/trips

### 11. Tenter d'accéder à un voyage inexistant (404)
GET {{baseUrl}}/trips/999999
Authorization: Bearer {{token}}

### 12. Tenter de créer un voyage avec des données invalides (422)
POST {{baseUrl}}/trips
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": "AB",
  "startDate": "2025-07-15",
  "endDate": "2025-07-01"
}

###############################################
# 🗺️ ÉTAPES (STOPS)
###############################################

### 13. Lister toutes les étapes d'un voyage
GET {{baseUrl}}/trips/{{tripId}}/stops
Authorization: Bearer {{token}}

### 14. Créer une étape (ordre automatique)
POST {{baseUrl}}/trips/{{tripId}}/stops
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": "Tour Eiffel",
  "description": "Visite guidée",
  "type": "activity",
  "latitude": 48.8584,
  "longitude": 2.2945,
  "address": "Champ de Mars, 5 Av. Anatole France, 75007 Paris"
}

### 15. Créer une deuxième étape (ordre automatique = 2)
POST {{baseUrl}}/trips/{{tripId}}/stops
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": "Louvre",
  "type": "activity",
  "latitude": 48.8606,
  "longitude": 2.3376,
  "address": "Rue de Rivoli, 75001 Paris"
}

### 16. Voir une étape spécifique
GET {{baseUrl}}/stops/1
Authorization: Bearer {{token}}

### 17. Modifier une étape
PATCH {{baseUrl}}/stops/1
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": "Tour Eiffel - MODIFIÉE",
  "isLocked": true
}

### 18. Supprimer une étape
DELETE {{baseUrl}}/stops/1
Authorization: Bearer {{token}}
